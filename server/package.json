{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "run": "tsc-watch --onSuccess \"node dist/index.js\"",
    "start:dev": "tsx watch --env-file=.env.development src/index.ts",
    "start:prod": "node --env-file=.env.production dist/index.js",
    "docker:dev": "docker compose up -d",
    "docker:prod": "docker compose -f docker-compose.production.yml up -d",
    "copy:prisma": "cpx \"src/generated/**/*\" dist/generated",
    "build": "tsc -p tsconfig.build.json && cpx \"src/generated/**/*\" dist/generated",
    "start": "node --env-file=.env.development dist/index.js",
    "build:compile": "tsc -b",
    "start:inspect": "node --inspect dist/index.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate"
  },
  "keywords": [],
  "author": "hmwaio",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@getbrevo/brevo": "^4.0.1",
    "@prisma/adapter-pg": "7.2.0",
    "@prisma/client": "7.2.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.0",
    "pg": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.0",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "prisma": "7.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  }
}
